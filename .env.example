# ─── Supabase (cliente + servidor) ───
# Copia este archivo como `.env.local` y rellena con los valores de tu proyecto.
# Los puedes encontrar en: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Solo para tareas en servidor que necesitan saltarse RLS (NUNCA exponer al cliente).
# Déjala vacía si no la usarás todavía.
SUPABASE_SERVICE_ROLE_KEY=
